# Elasticsearch connection
ES_NODE=http://127.0.0.1:9200
# Leave blank if security is disabled on your local ES
ES_USERNAME=
ES_PASSWORD=
# Set to false to ignore self-signed TLS certs on https ES nodes
ES_TLS_REJECT_UNAUTHORIZED=false

# Server
PORT=3000

# Auth — secret used to sign JWTs. Change this to a long random string.
JWT_SECRET=dev-change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
